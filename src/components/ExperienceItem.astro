---
interface Props {
  position: string;
  institution: string;
  location: string;
  description: string[];
  date: string;
  technologies?: string[];
}

const { position, institution, location, description, date, technologies } = Astro.props;
const isEnglish = Astro.url.pathname.startsWith("/en");
---

<div
  class="relative mx-12 pb-12 grid before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-black/20 dark:before:border-white/15 before:content-[''] md:grid-cols-5 md:gap-10 md:space-x-4"
>
  <div class="relative pb-6 md:pb-0 md:col-span-2">
    <div class="sticky top-0">
      <span class="text-yellow-400 -left-[42px] absolute rounded-full text-5xl"
        >&bull;</span
      >

      <h3 class="text-xl font-bold text-yellow-500 dark:text-yellow-400">{position}</h3>
      <h4 class="font-semibold text-lg text-zinc-700 dark:text-zinc-200">
        {institution}
      </h4>
      <div class="text-sm text-zinc-500 dark:text-zinc-400 mt-0.5">
        {location}
      </div>
      <time class="inline-block mt-2 text-sm font-semibold text-zinc-600 dark:text-zinc-300"
        >{date}</time
      >
      {
        technologies && (
          <div class="flex flex-wrap gap-1.5 mt-3">
            {technologies.map((tech) => (
              <span class="px-2 py-0.5 text-[11px] font-semibold rounded-md bg-zinc-200/60 dark:bg-zinc-800/60 text-zinc-700 dark:text-zinc-300 border border-zinc-300/30 dark:border-zinc-700/30 select-none">
                {tech}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </div>
  <div
    class="relative flex flex-col gap-2 text-zinc-600 dark:text-zinc-300 md:col-span-3"
  >
    <details class="group">
      <summary class="flex items-center gap-x-1.5 cursor-pointer text-sm font-semibold text-zinc-500 dark:text-zinc-400 hover:text-yellow-500 dark:hover:text-yellow-400 transition-colors select-none list-none [&::-webkit-details-marker]:hidden">
        <span>{isEnglish ? "Show details" : "Ver detalles"}</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="size-4 transition-transform duration-200 group-open:rotate-180"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2.5"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>

      <ul class="list-disc list-outside space-y-2 text-pretty text-sm md:text-base leading-relaxed pl-4 mt-4">
        {
          description.map((point) => (
            <li>{point}</li>
          ))
        }
      </ul>
    </details>
  </div>
</div>
