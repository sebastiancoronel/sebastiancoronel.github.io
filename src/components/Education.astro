---
import type { Education as EducationType } from "../data/cv";

interface Props {
  education: EducationType[];
}

const { education } = Astro.props;
---

<div class="flex flex-col gap-y-8 mt-6">
  {
    education.map(({ institution, major, date, location, link }) => (
      <div class="group relative flex flex-col md:flex-row md:justify-between items-start md:items-center p-5 rounded-2xl border border-zinc-200/80 dark:border-zinc-800/80 bg-white/40 dark:bg-zinc-900/30 backdrop-blur-sm transition-all duration-300 hover:shadow-md hover:border-zinc-300 dark:hover:border-zinc-700/80">
        <div>
          <h3 class="text-xl font-bold text-yellow-500 dark:text-yellow-400">
            {
              link ? (
                <a
                  href={link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:underline inline-flex items-center gap-x-1.5"
                >
                  {major}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="size-4 inline-block opacity-80"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                    />
                  </svg>
                </a>
              ) : (
                major
              )
            }
          </h3>
          <p class="text-lg font-semibold text-zinc-700 dark:text-zinc-300 mt-1">
            {institution}
          </p>
        </div>
        <div class="flex flex-col items-start md:items-end mt-2 md:mt-0 text-sm text-zinc-500 dark:text-zinc-400">
          <time class="font-medium text-zinc-600 dark:text-zinc-300">{date}</time>
          <span class="mt-0.5">{location}</span>
        </div>
      </div>
    ))
  }
</div>
